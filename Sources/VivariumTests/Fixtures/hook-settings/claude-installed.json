{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vivarium/notify --agent claude-code --event SessionStart"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vivarium/notify --agent claude-code --event PreToolUse"
          }
        ]
      }
    ]
  }
}
