#!/usr/bin/env bash
# build — produce LittleGuy.app you can run without Xcode.
#
# Builds the LittleGuy scheme into ./build/ via xcodebuild and prints the
# path of the resulting .app bundle. Defaults to Release; pass --debug for
# a debug build. Pass --open to launch the .app once it's built.
#
# Usage:
#   ./build              # Release build
#   ./build --debug      # Debug build
#   ./build --open       # Build Release and `open` the resulting .app

set -euo pipefail

CONFIG="Release"
OPEN_AFTER=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --debug)        CONFIG="Debug" ;;
    --release)      CONFIG="Release" ;;
    --open)         OPEN_AFTER=1 ;;
    -h|--help)      grep '^#' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)              echo "ERROR: unknown argument '$1'" >&2; exit 1 ;;
  esac
  shift
done

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$REPO_ROOT"

# `dist/` rather than `build/` so the derivedDataPath doesn't collide
# with this script's own filename in the repo root.
DERIVED="$REPO_ROOT/dist"
APP_PATH="$DERIVED/Build/Products/$CONFIG/LittleGuy.app"

echo "==> Building LittleGuy ($CONFIG)"
# Stream raw xcodebuild output through xcbeautify when it's available
# (compact, colourised) and fall back to plain output otherwise.
if command -v xcbeautify >/dev/null 2>&1; then
  set -o pipefail
  xcodebuild \
    -project LittleGuy.xcodeproj \
    -scheme LittleGuy \
    -configuration "$CONFIG" \
    -destination 'platform=macOS' \
    -derivedDataPath "$DERIVED" \
    build | xcbeautify
else
  xcodebuild \
    -project LittleGuy.xcodeproj \
    -scheme LittleGuy \
    -configuration "$CONFIG" \
    -destination 'platform=macOS' \
    -derivedDataPath "$DERIVED" \
    build
fi

if [[ ! -d "$APP_PATH" ]]; then
  echo "ERROR: build succeeded but .app not found at $APP_PATH" >&2
  exit 1
fi

echo
echo "==> Done."
echo "App: $APP_PATH"

if [[ "$OPEN_AFTER" -eq 1 ]]; then
  open "$APP_PATH"
fi
